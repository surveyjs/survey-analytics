{
  "version": "3.0.0-beta.5",
  "name": "survey-analytics",
  "scripts": {
    "serve": "http-server --silent",
    "test": "vitest run",
    "test:dev": "vitest --watch",
    "test:debug": "vitest --inspect-brk --no-file-parallelism",
    "e2e": "playwright test --project chromium --ui",
    "e2e:apexCharts": "playwright test --project chromium+apexCharts --ui",
    "e2e:chartjs": "playwright test --project chromium+chartjs --ui",
    "e2e:ci": "playwright test --project chromium --project chromium+apexCharts --project chromium+chartjs",
    "e2e:ci:apexCharts": "playwright test --project chromium+apexCharts",
    "e2e:ci:chartjs": "playwright test --project chromium+chartjs",
    "e2e:ci:plotly": "playwright test --project chromium",
    "release": "standard-version --message \"Release: %s [azurepipelines skip]\" ",
    "doc:gen": "node doc_generator/lib_docgenerator.js src/index.ts",
    "doc:update": "chmod +x ./docupdate_npm.sh && ./docupdate_npm.sh",
    "watch:dev": "rollup -c --environment mode:dev -w",
    "build:all": "npm run build && npm run build:themes",
    "build": "npm run build:dev && npm run build:prod && rollup -c && npm run build:types",
    "build:dev": "rollup -c --environment mode:dev",
    "build:prod": "rollup -c --environment mode:prod",
    "build:themes": "rollup -c rollup.config.themes.js",
    "build:types": "npm run build:types:core && npm run build:types:tabulator && npm run build:types:mongo && npm run build:types:apexcharts && npm run build:types:chartjs && npm run build:types:plotly",
    "build:types:core": "tsc --p tsconfig.types.summary.core.json && echo \"export * from './survey-analytics.types/entries/summary.core';\" >> build/survey.analytics.core.d.ts",
    "build:types:tabulator": "tsc --p tsconfig.types.tabulator.json && echo \"export * from './survey-analytics-tabulator.types/entries/tabulator';\" >> build/survey.analytics.tabulator.d.ts",
    "build:types:apexcharts": "tsc --p tsconfig.types.apexcharts.json && echo \"export * from './survey-analytics-apexcharts.types/entries/apexcharts';\" >> build/survey.analytics.apexcharts.d.ts",
    "build:types:chartjs": "tsc --p tsconfig.types.chartjs.json && echo \"export * from './survey-analytics-chartjs.types/entries/chartjs';\" >> build/survey.analytics.analytics.d.ts",
    "build:types:plotly": "tsc --p tsconfig.types.plotly.json && echo \"export * from './survey-analytics-plotly.types/entries/plotly';\" >> build/survey.analytics.plotly.d.ts",
    "build:types:mongo": "tsc --p tsconfig.types.mongo.json && echo \"export * from './survey-analytics.types/entries/mongo';\" >> build/survey.analytics.mongo.d.ts",
    "accessibility-tests": "playwright test --project a11y --ui",
    "accessibility-tests:ci": "playwright test --project a11y --reporter dot --quiet",
    "lint": "eslint . --ext .js,.cjs,.mjs,.ts,.cts,.mts --max-warnings=0",
    "lint:fix": "eslint . --ext .js,.cjs,.mjs,.ts,.cts,.mts --max-warnings=0 --fix",
    "pre-push-check": "npm run lint",
    "pwinst": "playwright install chromium"
  },
  "main": "survey.analytics.js",
  "files": [
    "**/*"
  ],
  "typings": "survey.analytics.d.ts",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/surveyjs/survey-analytics.git"
  },
  "dependencies": {
    "apexcharts": "^4.7.0",
    "chart.js": "^4.5.1",
    "chartjs-plugin-datalabels": "^2.2.0",
    "mongodb": "^6.20.0",
    "muuri": "^0.8.0",
    "plotly.js-dist-min": "^2.28.0",
    "survey-core": "../survey-library/packages/survey-core/build",
    "tabulator-tables": "^6.2.5"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@playwright/test": "1.60.0",
    "@rollup/plugin-commonjs": "^28.0.2",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-replace": "^6.0.2",
    "@rollup/plugin-typescript": "^12.1.2",
    "@rushstack/eslint-patch": "^1.1.4",
    "@types/minimatch": "5.1.2",
    "@types/node": "^20.19.0",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "@vitest/coverage-istanbul": "^4.1.7",
    "axe-core": "^4.8.2",
    "axe-playwright": "^2.1.0",
    "concurrently": "^5.3.0",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.0",
    "eslint-plugin-surveyjs": "git+https://github.com/surveyjs/eslint-surveyjs.git",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "jsdom": "^24.1.3",
    "lint-staged": "^15.4.3",
    "mongodb-memory-server": "^10.2.1",
    "node-uuid": "1.4.7",
    "playwright": "1.60.0",
    "puppeteer": "22.13.1",
    "replace-in-file": "^6.3.2",
    "rollup": "^4.59.0",
    "rollup-plugin-esbuild": "^6.2.1",
    "rollup-plugin-license": "^3.7.1",
    "sass": "^1.62.1",
    "standard-version": "^9.5.0",
    "surveyjs-doc-generator": "git+https://github.com/surveyjs/surveyjs-doc-generator.git",
    "svg-inline-loader": "^0.8.2",
    "terser": "^5.47.1",
    "ts-loader": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.7",
    "vitest-canvas-mock": "^0.3.3"
  },
  "peerDependencies": {
    "@types/mongodb": "^4.0.6",
    "@types/plotly.js-dist-min": "^2.3.0",
    "@types/tabulator-tables": "^6.2.3"
  },
  "husky": {
    "hooks": {
      "pre-push": "npm run pre-push-check"
    }
  },
  "lint-staged": {
    "**/*.{js,cjs,mjs,ts,cts,mts}": [
      "eslint --fix"
    ]
  }
}
